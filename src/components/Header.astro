---
interface Props {
	currentPath?: string;
}

const { currentPath = "/" } = Astro.props;
---

<header class="relative z-50 border-b border-slate-200/80 bg-white/90 backdrop-blur">
	<div class="mx-auto max-w-6xl px-6">
		<div class="flex flex-wrap gap-1 border-b border-slate-200/70 py-1 text-[11px] text-slate-600 items-center justify-end sm:gap-3">
			<a class="transition-colors hover:text-slate-900" href="mailto:upperhandinternational@gmail.com">upperhandinternational@gmail.com</a>
			<a class="transition-colors hover:text-slate-900" href="tel:8155230669">(815) 523-0669</a>
		</div>
		<nav class="flex items-center justify-between py-2.5">
			<div class="flex items-center gap-3">
				<img src="/logo.png" alt="Upper Hand International Logo" class="h-9 w-auto" />
				<a href="/" class="text-sm font-semibold text-slate-900">Upper Hand International</a>
			</div>
			<div class="relative md:hidden" id="mobile-menu-container">
				<button id="mobile-menu-button" type="button" class="flex h-9 w-9 items-center justify-center rounded-md text-slate-700 transition hover:bg-slate-50" aria-label="Open menu" aria-controls="mobile-menu-panel" aria-expanded="false">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
					</svg>
				</button>
			</div>
			<ul class="hidden items-center gap-5 text-xs font-medium text-slate-600 md:flex">
				<li><a class="transition-colors hover:text-slate-900" href="/#about">About</a></li>
				<li><a class="transition-colors hover:text-slate-900" href="/#projects">Projects</a></li>
				<li><a class="transition-colors hover:text-slate-900" href="/#additional-work">Additional Work</a></li>
				<li><a class="transition-colors hover:text-slate-900" href="/blog">Blog</a></li>
				<li><a class="transition-colors hover:text-slate-900" href="/#contact">Donate</a></li>
			</ul>
		</nav>
	</div>
</header>

<div id="mobile-menu" class="pointer-events-none fixed inset-0 z-120 md:hidden">
	<button id="mobile-menu-overlay" type="button" class="absolute inset-0 bg-slate-900/35 opacity-0 transition-opacity duration-300" aria-label="Close menu"></button>
	<div id="mobile-menu-panel" class="absolute inset-0 h-full w-full translate-x-full bg-white p-6 shadow-2xl transition-transform duration-300 ease-out">
		<div class="mb-4 flex items-center justify-between border-b border-slate-200 pb-3">
			<p class="text-sm font-semibold text-slate-900">Menu</p>
			<button id="mobile-menu-close" type="button" class="rounded-md p-1 text-slate-600 transition hover:bg-slate-100 hover:text-slate-900" aria-label="Close menu">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
				</svg>
			</button>
		</div>
		<a class="block rounded-md px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50 hover:text-slate-900" href="/#about">About</a>
		<a class="mt-1 block rounded-md px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50 hover:text-slate-900" href="/#projects">Projects</a>
		<a class="mt-1 block rounded-md px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50 hover:text-slate-900" href="/#additional-work">Additional Work</a>
		<a class="mt-1 block rounded-md px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50 hover:text-slate-900" href="/blog">Blog</a>
		<a class="mt-1 block rounded-md px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-50 hover:text-slate-900" href="/#contact">Donate</a>
	</div>
</div>

<script>
	const mobileMenuButton = document.getElementById('mobile-menu-button');
	const mobileMenu = document.getElementById('mobile-menu');
	const mobileMenuPanel = document.getElementById('mobile-menu-panel');
	const mobileMenuOverlay = document.getElementById('mobile-menu-overlay');
	const mobileMenuClose = document.getElementById('mobile-menu-close');

	if (mobileMenuButton && mobileMenu && mobileMenuPanel && mobileMenuOverlay && mobileMenuClose) {
		let closeTimer: number | undefined;

		const openMenu = () => {
			if (closeTimer) {
				clearTimeout(closeTimer);
			}
			mobileMenu.classList.remove('pointer-events-none');
			mobileMenuOverlay.classList.remove('opacity-0');
			mobileMenuPanel.classList.remove('translate-x-full');
			mobileMenuButton.setAttribute('aria-expanded', 'true');
		};

		const closeMenu = () => {
			mobileMenuOverlay.classList.add('opacity-0');
			mobileMenuPanel.classList.add('translate-x-full');
			mobileMenuButton.setAttribute('aria-expanded', 'false');
			closeTimer = window.setTimeout(() => {
				mobileMenu.classList.add('pointer-events-none');
			}, 300);
		};

		mobileMenuButton.addEventListener('click', () => {
			const isClosed = mobileMenu.classList.contains('pointer-events-none');
			if (isClosed) {
				openMenu();
			} else {
				closeMenu();
			}
		});

		mobileMenuOverlay.addEventListener('click', closeMenu);
		mobileMenuClose.addEventListener('click', closeMenu);

		mobileMenu.querySelectorAll('a').forEach((link) => {
			link.addEventListener('click', closeMenu);
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape' && !mobileMenu.classList.contains('pointer-events-none')) {
				closeMenu();
			}
		});
	}
</script>

