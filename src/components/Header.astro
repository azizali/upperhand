---
interface Props {
	currentPath?: string;
}

const { currentPath = "/" } = Astro.props;
---

<header class="sticky top-0 z-50 border-b border-slate-200/80 bg-white/90 backdrop-blur">
	<div class="mx-auto max-w-6xl px-6">
		<nav class="flex items-center justify-between py-4">
			<div class="flex items-center gap-3">
				<img src="/logo.png" alt="Upper Hand International Logo" class="h-12 w-auto" />
				<a href="/" class="text-base font-semibold text-slate-900">Upper Hand International</a>
			</div>
			<ul class="hidden items-center gap-6 text-sm font-medium text-slate-600 md:flex">
				<li><a class="transition-colors hover:text-slate-900" href="/#about">About</a></li>
				<li><a class="transition-colors hover:text-slate-900" href="/#projects">Projects</a></li>
				<li><a class="transition-colors hover:text-slate-900" href="/#additional-work">Additional Work</a></li>
				<li><a class="transition-colors hover:text-slate-900" href="/#message">Message</a></li>
				<li><a class="transition-colors hover:text-slate-900" href="/#blog">Blog</a></li>
				<li><a class="transition-colors hover:text-slate-900" href="/#contact">Contact</a></li>
			</ul>
		</nav>
	</div>
</header>

