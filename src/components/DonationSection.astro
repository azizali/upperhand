---
// Reusable donation section component
---

<div class="mb-12 rounded-2xl border border-slate-800 bg-slate-900 p-8 text-center md:p-10">
	<h3 class="text-2xl font-semibold text-white md:text-3xl">Support Our Mission</h3>
	<p class="mt-3 text-base text-slate-300">Your generosity helps us serve communities in need</p>
	<div class="mt-8 flex flex-col items-center justify-center gap-8 md:flex-row md:gap-12">
		<div class="flex flex-col items-center">
			<img src="/qr-code-zelle.svg" alt="Zelle QR Code" class="h-48 w-48 rounded-xl border-4 border-white bg-white p-2" />
			<p class="mt-4 text-lg font-semibold text-white">Donate Now</p>
		</div>
		<div class="max-w-sm text-center md:text-left">
			<p class="text-base font-medium text-slate-200">Send your donation via Zelle to:</p>
			<p class="mt-2 text-lg font-semibold text-white">
				<a class="underline decoration-slate-500 underline-offset-4 transition hover:text-slate-100" href="&#109;&#97;&#105;&#108;&#116;&#111;&#58;&#117;&#112;&#112;&#101;&#114;&#104;&#97;&#110;&#100;&#105;&#110;&#116;&#101;&#114;&#110;&#97;&#116;&#105;&#111;&#110;&#97;&#108;&#64;&#103;&#109;&#97;&#105;&#108;&#46;&#99;&#111;&#109;">&#117;&#112;&#112;&#101;&#114;&#104;&#97;&#110;&#100;&#105;&#110;&#116;&#101;&#114;&#110;&#97;&#116;&#105;&#111;&#110;&#97;&#108;&#64;&#103;&#109;&#97;&#105;&#108;&#46;&#99;&#111;&#109;</a>
			</p>
			<p class="mt-4 text-sm text-slate-400">All donations are tax-deductible. 501(c) Non-Profit Organization</p>
		</div>
	</div>
</div>

