---
import DonationSection from './DonationSection.astro';
---

<footer id="contact" class="border-t border-slate-900/10 bg-slate-950 py-14 text-slate-200">
	<div class="mx-auto max-w-6xl px-6">
		<!-- Donation Section -->
		<DonationSection />

		<div class="grid gap-8 md:grid-cols-3">
			<div>
				<h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">Contact Us</h3>
				<p class="mt-2 text-sm">
				<a class="text-slate-100 underline decoration-slate-500 underline-offset-4 transition hover:text-white" href="&#109;&#97;&#105;&#108;&#116;&#111;&#58;&#117;&#112;&#112;&#101;&#114;&#104;&#97;&#110;&#100;&#105;&#110;&#116;&#101;&#114;&#110;&#97;&#116;&#105;&#111;&#110;&#97;&#108;&#64;&#103;&#109;&#97;&#105;&#108;&#46;&#99;&#111;&#109;">&#117;&#112;&#112;&#101;&#114;&#104;&#97;&#110;&#100;&#105;&#110;&#116;&#101;&#114;&#110;&#97;&#116;&#105;&#111;&#110;&#97;&#108;&#64;&#103;&#109;&#97;&#105;&#108;&#46;&#99;&#111;&#109;</a>
				</p>
			</div>
			<div>
				<h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">Leadership</h3>
				<p class="mt-4 text-sm text-slate-300">Faheem Shahzad - President</p>
				<p class="mt-2 text-sm text-slate-300">Dr. Shahid Sharer - Secretary</p>
				<p class="mt-2 text-sm text-slate-300">Qazi M Yousaf - Treasurer</p>
			</div>
			<div>
				<h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">Supported By</h3>
				<img src="/apa-bolingbrook.jpeg" alt="APA Bolingbrook" class="mt-4 h-auto w-36 rounded-xl border border-slate-800" />
				<p class="mt-2 text-sm font-medium text-slate-300">APA Bolingbrook</p>
			</div>
		</div>
		<div class="mt-10 border-t border-slate-800 pt-6 text-center text-xs text-slate-400">
			<p>&copy; {new Date().getFullYear()} Upper Hand International. All rights reserved. 501(c) Non-Profit Organization</p>
			<p class="mt-2">Site made by <a class="text-slate-200 underline decoration-slate-600 underline-offset-4 transition hover:text-white" href="https://betterstarter.dev" target="_blank" rel="noopener noreferrer">BetterStarter.dev</a></p>
		</div>
	</div>
</footer>

