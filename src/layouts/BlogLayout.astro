---
const { frontmatter } = Astro.props;
import BaseLayout from './BaseLayout.astro';
---

<BaseLayout
	title={`${frontmatter.title} - Upper Hand International`}
	description={frontmatter.excerpt}
>
	<!-- Blog Post Content -->
		<article class="py-12">
			<div class="mx-auto max-w-6xl px-6">
				<div class="mx-auto max-w-3xl">
					<a href="/#blog" class="text-sm font-semibold text-slate-600 underline decoration-slate-300 underline-offset-4 transition hover:text-slate-900">← Back to Blog</a>
					<h1 class="mt-6 text-4xl font-semibold tracking-tight text-slate-900">{frontmatter.title}</h1>
					<div class="mt-3 text-sm text-slate-500">
						<span class="font-medium">{frontmatter.date}</span>
						{frontmatter.author && (
							<span class="italic"> • By {frontmatter.author}</span>
						)}
					</div>
				</div>
				<div class="post-content mx-auto mt-10 max-w-3xl rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
					<slot />
				</div>
				<div class="mx-auto mt-8 max-w-3xl">
					<a href="/#blog" class="text-sm font-semibold text-slate-600 underline decoration-slate-300 underline-offset-4 transition hover:text-slate-900">← Back to all posts</a>
				</div>
			</div>
		</article>
</BaseLayout>
