---
import homeContent from '../data/home-content.json';
import BaseLayout from '../layouts/BaseLayout.astro';

// Get all project images
const projectImages = [
	'/projects/project1.jpeg',
	'/projects/project1b.jpeg',
	'/projects/project2.jpeg',
	'/projects/project3.jpeg',
	'/projects/project4.jpeg',
	'/projects/project4b.jpeg',
	'/projects/project5.jpeg',
	'/projects/project5b.jpeg',
	'/projects/project6.jpeg',
	'/projects/project6b.jpeg',
	'/projects/project7.jpeg',
	'/projects/project7b.jpeg',
	'/projects/project7c.jpeg',
	'/projects/project8.jpeg',
	'/projects/project9.jpeg',
	'/projects/project10.jpeg',
	'/projects/project11.jpeg',
];

// Get blog posts
const blogPosts = await Astro.glob('./blog/*.md');
const recentPosts = blogPosts.slice(0, 3);
---

<BaseLayout>
	<!-- Hero Section -->
		<section class="relative overflow-hidden bg-slate-50">
			<div class="absolute inset-0 bg-[url('/projects/project1.jpeg')] bg-cover bg-center opacity-10"></div>
			<div class="relative mx-auto flex min-h-95 max-w-6xl flex-col items-center justify-center px-6 py-12 text-center md:min-h-105 md:py-14">
				<p class="mb-3 text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">{homeContent.hero.eyebrow}</p>
				<h1 class="text-3xl font-semibold tracking-tight text-slate-900 md:text-4xl">
					{homeContent.hero.title}
				</h1>
				<p class="mt-4 max-w-xl text-base text-slate-600 md:text-lg">
					{homeContent.hero.description}
				</p>
				<a href={homeContent.hero.ctaHref} class="mt-6 inline-flex items-center justify-center rounded-full border border-slate-900 bg-slate-900 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-800">
					{homeContent.hero.ctaLabel}
				</a>
			</div>
		</section>

		<!-- About Section -->
		<section id="about" class="bg-white py-16 md:py-24">
			<div class="mx-auto max-w-6xl px-6">
				<h2 class="text-3xl font-semibold tracking-tight text-slate-900 md:text-4xl">{homeContent.mission.heading}</h2>
				<p class="mt-3 max-w-2xl text-lg text-slate-600">
					{homeContent.mission.subheading}
				</p>
				<div class="mt-10 grid gap-10 md:grid-cols-2 md:items-center">
					<div class="space-y-4 text-base text-slate-700">
						<p class="text-lg font-medium text-slate-900">{homeContent.mission.intro}</p>
						{homeContent.mission.paragraphs.map((paragraph) => (
							<p>{paragraph}</p>
						))}
					</div>
					<div class="grid gap-4">
						{homeContent.mission.stats.map((stat) => (
							<div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
								<div class="text-2xl font-semibold text-slate-900">{stat.value}</div>
								<div class="text-sm text-slate-600">{stat.label}</div>
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- Projects Gallery -->
		<section id="projects" class="border-t border-slate-100 bg-white py-16 md:py-24">
			<div class="mx-auto max-w-6xl px-6">
				<h2 class="text-3xl font-semibold tracking-tight text-slate-900 md:text-4xl">Our Projects</h2>
				<p class="mt-3 text-lg text-slate-600">Bringing clean water to communities in Thar, Pakistan</p>
				<div class="mt-10 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5">
					{projectImages.map((image) => (
						<div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
							<img src={image} alt="Water pump project in Thar" loading="lazy" class="aspect-square w-full object-cover transition duration-500 hover:scale-105" />
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Additional Work Section -->
		<section id="additional-work" class="border-t border-slate-100 bg-slate-50 py-16 md:py-24">
			<div class="mx-auto max-w-6xl px-6">
				<h2 class="text-3xl font-semibold tracking-tight text-slate-900 md:text-4xl">{homeContent.additionalWork.heading}</h2>
				<p class="mt-3 text-lg text-slate-600">{homeContent.additionalWork.subheading}</p>

				<div class="mt-10 grid gap-8 md:grid-cols-2">
					{homeContent.additionalWork.items.map((item) => (
						<div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm md:p-10">
							<div class="flex items-start justify-between gap-4">
								<h3 class="text-2xl font-semibold text-slate-900">{item.title}</h3>
								{item.badge && <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700 border border-emerald-200">{item.badge}</span>}
							</div>
							{item.paragraphs.map((paragraph, paragraphIndex) => (
								<p class:list={["text-base leading-7 text-slate-700", paragraphIndex === 0 ? "mt-4" : "mt-4"]}>{paragraph}</p>
							))}
							{item.bullets.length > 0 && (
								<ul class="mt-4 space-y-2 text-base text-slate-700">
									{item.bullets.map((bullet) => (
										<li class="flex items-start">
											<span class="mr-2 mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-slate-400"></span>
											<span>{bullet}</span>
										</li>
									))}
								</ul>
							)}
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Founder's Message -->
		<section id="message" class="border-t border-slate-100 bg-white py-16 md:py-24">
			<div class="mx-auto max-w-6xl px-6">
				<div class="max-w-3xl">
					<h2 class="text-3xl font-semibold tracking-tight text-slate-900 md:text-4xl">{homeContent.presidentMessage.heading}</h2>
					<div class="mt-8 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm md:p-10">
						{homeContent.presidentMessage.greeting && <p class="text-base italic text-slate-700">{homeContent.presidentMessage.greeting}</p>}
						{homeContent.presidentMessage.paragraphs.map((paragraph) => (
							<p class="mt-4 text-base leading-7 text-slate-700">{paragraph}</p>
						))}
						<p class="mt-6 text-base font-medium text-slate-900">{homeContent.presidentMessage.closing}</p>
						<div class="mt-8 border-t border-slate-200 pt-6">
							<p class="text-base font-semibold text-slate-900">{homeContent.presidentMessage.name}</p>
							<p class="text-sm text-slate-600">{homeContent.presidentMessage.role}</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Blog Section -->
		<section id="blog" class="border-t border-slate-100 bg-white py-16 md:py-24">
			<div class="mx-auto max-w-6xl px-6">
				<h2 class="text-3xl font-semibold tracking-tight text-slate-900 md:text-4xl">Latest Updates</h2>
				<p class="mt-3 text-lg text-slate-600">Stories from the field and organization news</p>
				{recentPosts.length > 0 ? (
					<div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
						{recentPosts.map((post) => (
							<a href={post.url} class="flex h-full flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
								<h3 class="text-lg font-semibold text-slate-900">{post.frontmatter.title}</h3>
								<p class="mt-2 text-xs font-medium uppercase tracking-[0.2em] text-slate-500">{post.frontmatter.date}</p>
								<p class="mt-4 text-sm text-slate-600">{post.frontmatter.excerpt}</p>
								<span class="mt-6 text-sm font-semibold text-slate-900 underline decoration-slate-300 underline-offset-4 transition hover:text-slate-700">Read more →</span>
							</a>
						))}
					</div>
				) : (
					<div class="mt-8 rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-6 text-sm text-slate-600">
						Check back soon for updates on our latest projects and initiatives!
					</div>
				)}
			</div>
		</section>
</BaseLayout>
