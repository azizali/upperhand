---
import BaseLayout from '../layouts/BaseLayout.astro';

// Get all project images
const projectImages = [
	'/projects/project1.jpeg',
	'/projects/project1b.jpeg',
	'/projects/project2.jpeg',
	'/projects/project3.jpeg',
	'/projects/project4.jpeg',
	'/projects/project4b.jpeg',
	'/projects/project5.jpeg',
	'/projects/project5b.jpeg',
	'/projects/project6.jpeg',
	'/projects/project6b.jpeg',
	'/projects/project7.jpeg',
	'/projects/project7b.jpeg',
	'/projects/project7c.jpeg',
	'/projects/project8.jpeg',
];

// Get blog posts
const blogPosts = await Astro.glob('./blog/*.md');
const recentPosts = blogPosts.slice(0, 3);
---

<BaseLayout>
	<!-- Hero Section -->
		<section class="relative overflow-hidden bg-slate-50">
			<div class="absolute inset-0 bg-[url('/projects/project1.jpeg')] bg-cover bg-center opacity-10"></div>
			<div class="relative mx-auto flex min-h-[520px] max-w-6xl flex-col items-center justify-center px-6 py-20 text-center">
				<p class="mb-4 text-xs font-semibold uppercase tracking-[0.3em] text-slate-500">Upper Hand International</p>
				<h1 class="text-4xl font-semibold tracking-tight text-slate-900 md:text-5xl">
					Extending a Helping Hand<br/>to Those in Need
				</h1>
				<p class="mt-5 max-w-2xl text-lg text-slate-600">
					Creating sustainable water solutions in Pakistan's Thar Desert
				</p>
				<a href="#projects" class="mt-8 inline-flex items-center justify-center rounded-full border border-slate-900 bg-slate-900 px-6 py-3 text-sm font-semibold text-white transition hover:bg-slate-800">
					See Our Impact
				</a>
			</div>
		</section>

		<!-- About Section -->
		<section id="about" class="bg-white py-16 md:py-24">
			<div class="mx-auto max-w-6xl px-6">
				<h2 class="text-3xl font-semibold tracking-tight text-slate-900 md:text-4xl">Our Mission</h2>
				<p class="mt-3 max-w-2xl text-lg text-slate-600">
					Serving humanity with compassion, integrity, and transparency.
				</p>
				<div class="mt-10 grid gap-10 md:grid-cols-2 md:items-center">
					<div class="space-y-4 text-base text-slate-700">
						<p class="text-lg font-medium text-slate-900">At Upper Hand International, we are committed to serving humanity with compassion, integrity, and transparency.</p>
						<p>As a non-profit charitable organization, our mission is to create meaningful change by supporting vulnerable families, empowering individuals, and responding to the needs of those who require assistance the most.</p>
						<p>We specialize in creating sustainable water pump solutions in Pakistan's Thar region, bringing clean water to communities that need it most.</p>
					</div>
					<div class="grid gap-4">
						<div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
							<div class="text-2xl font-semibold text-slate-900">100+</div>
							<div class="text-sm text-slate-600">Water Pumps Installed</div>
						</div>
						<div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
							<div class="text-2xl font-semibold text-slate-900">1000+</div>
							<div class="text-sm text-slate-600">Families Served</div>
						</div>
						<div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
							<div class="text-2xl font-semibold text-slate-900">501(c)</div>
							<div class="text-sm text-slate-600">Non-Profit Status</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Projects Gallery -->
		<section id="projects" class="border-t border-slate-100 bg-white py-16 md:py-24">
			<div class="mx-auto max-w-6xl px-6">
				<h2 class="text-3xl font-semibold tracking-tight text-slate-900 md:text-4xl">Our Projects</h2>
				<p class="mt-3 text-lg text-slate-600">Bringing clean water to communities in Thar, Pakistan</p>
				<div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
					{projectImages.map((image) => (
						<div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
							<img src={image} alt="Water pump project in Thar" loading="lazy" class="aspect-[4/3] w-full object-cover transition duration-500 hover:scale-105" />
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Additional Work Section -->
		<section id="additional-work" class="border-t border-slate-100 bg-slate-50 py-16 md:py-24">
			<div class="mx-auto max-w-6xl px-6">
				<h2 class="text-3xl font-semibold tracking-tight text-slate-900 md:text-4xl">Additional Work</h2>
				<p class="mt-3 text-lg text-slate-600">Expanding our reach to serve communities in need</p>

				<div class="mt-10 grid gap-8 md:grid-cols-2">
					<!-- Hardship Assistance -->
					<div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm md:p-10">
						<div class="flex items-start justify-between">
							<h3 class="text-2xl font-semibold text-slate-900">Hardship Assistance</h3>
							<span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700 border border-emerald-200">Zakaat & Sadaqa Eligible</span>
						</div>
						<p class="mt-4 text-base leading-7 text-slate-700">
							Hardship Assistance Program for individuals and families living in the United States.
							This program is designed to support community members who are facing financial difficulties. We provide assistance for essential needs such as:
						</p>
						<ul class="mt-4 space-y-2 text-base text-slate-700">
							<li class="flex items-start">
								<span class="mr-2 mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-slate-400"></span>
								<span>Rental support</span>
							</li>
							<li class="flex items-start">
								<span class="mr-2 mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-slate-400"></span>
								<span>Utility bills</span>
							</li>
							<li class="flex items-start">
								<span class="mr-2 mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-slate-400"></span>
								<span>Daily living expenses</span>
							</li>
						</ul>
						<p class="mt-4 text-base leading-7 text-slate-700">
							Our goal is to help individuals and families regain stability during challenging times while ensuring that financial hardship does not prevent access to basic necessities.
						</p>
					</div>

					<!-- International Scholarship -->
					<div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm md:p-10">
						<div class="flex items-start justify-between">
							<h3 class="text-2xl font-semibold text-slate-900">International Scholarship</h3>
							<span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700 border border-emerald-200">Zakaat & Sadaqa Eligible</span>
						</div>
						<p class="mt-4 text-base leading-7 text-slate-700">
							International scholarship program designed to support talented and motivated students from around the world.
							Through this initiative, we extend opportunities to students in countries such as Pakistan, who are eager to pursue their studies abroad. Selected students are given the chance to study here, and Upperhand International takes responsibility for covering their semester tuition fees.
						</p>
						<p class="mt-4 text-base leading-7 text-slate-700">
							Our goal is to remove financial barriers and empower deserving students with access to quality education, helping them build a brighter future while promoting global academic collaboration and cultural exchange.
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Founder's Message -->
		<section id="message" class="border-t border-slate-100 bg-white py-16 md:py-24">
			<div class="mx-auto max-w-6xl px-6">
				<div class="max-w-3xl">
					<h2 class="text-3xl font-semibold tracking-tight text-slate-900 md:text-4xl">A Message from Our President</h2>
					<div class="mt-8 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm md:p-10">
						<p class="text-base italic text-slate-700">Dear Friends, Supporters, and Members of Our Community,</p>
						<p class="mt-4 text-base leading-7 text-slate-700">As President of Upper Hand International, it is both an honor and a responsibility to address you today. Our organization was founded on a simple but powerful belief — that when we extend a helping hand to those in need, we uplift not only individuals, but entire communities.</p>
						<p class="mt-4 text-base leading-7 text-slate-700">At Upper Hand International, we are committed to serving humanity with compassion, integrity, and transparency. As a non-profit charitable organization, our mission is to create meaningful change by supporting vulnerable families, empowering individuals, and responding to the needs of those who require assistance the most.</p>
						<p class="mt-4 text-base leading-7 text-slate-700">None of our efforts would be possible without the generosity, trust, and continued support of people like you. Whether you contribute your time, resources, expertise, or prayers, you are an essential part of this mission. Together, we are building hope, restoring dignity, and creating opportunities for a brighter future.</p>
						<p class="mt-4 text-base leading-7 text-slate-700">While we are proud of the progress we have made, there is still much work ahead. The challenges facing our communities require unity, compassion, and action. I invite you to continue standing with us — to advocate, to support, and to help us expand our reach so that no one feels forgotten or alone.</p>
						<p class="mt-4 text-base leading-7 text-slate-700">On behalf of Upper Hand International, I extend my deepest gratitude to every volunteer, donor, partner, and supporter. Your belief in our mission inspires us to work harder and reach further.</p>
						<p class="mt-6 text-base font-medium text-slate-900">Together, we can continue to make a lasting difference.</p>
						<div class="mt-8 border-t border-slate-200 pt-6">
							<p class="text-base font-semibold text-slate-900">Faheem Shahzad</p>
							<p class="text-sm text-slate-600">President, Upper Hand International</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Blog Section -->
		<section id="blog" class="border-t border-slate-100 bg-white py-16 md:py-24">
			<div class="mx-auto max-w-6xl px-6">
				<h2 class="text-3xl font-semibold tracking-tight text-slate-900 md:text-4xl">Latest Updates</h2>
				<p class="mt-3 text-lg text-slate-600">Stories from the field and organization news</p>
				{recentPosts.length > 0 ? (
					<div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
						{recentPosts.map((post) => (
							<a href={post.url} class="flex h-full flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
								<h3 class="text-lg font-semibold text-slate-900">{post.frontmatter.title}</h3>
								<p class="mt-2 text-xs font-medium uppercase tracking-[0.2em] text-slate-500">{post.frontmatter.date}</p>
								<p class="mt-4 text-sm text-slate-600">{post.frontmatter.excerpt}</p>
								<span class="mt-6 text-sm font-semibold text-slate-900 underline decoration-slate-300 underline-offset-4 transition hover:text-slate-700">Read more →</span>
							</a>
						))}
					</div>
				) : (
					<div class="mt-8 rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-6 text-sm text-slate-600">
						Check back soon for updates on our latest projects and initiatives!
					</div>
				)}
			</div>
		</section>
</BaseLayout>
