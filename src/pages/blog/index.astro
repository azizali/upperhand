---
import BaseLayout from '../../layouts/BaseLayout.astro';

const blogPosts = await Astro.glob('./*.md');

const allPosts = blogPosts.sort((a, b) => {
	const dateA = new Date(a.frontmatter.date).getTime();
	const dateB = new Date(b.frontmatter.date).getTime();
	return dateB - dateA;
});
---

<BaseLayout
	title="Blog - Upper Hand International"
	description="Updates, stories, and project news from Upper Hand International."
	currentPath="/blog"
>
	<section class="border-t border-slate-100 bg-white py-16 md:py-24">
		<div class="mx-auto max-w-6xl px-6">
			<h1 class="text-3xl font-semibold tracking-tight text-slate-900 md:text-4xl">All Blog Posts</h1>
			<p class="mt-3 text-lg text-slate-600">Stories from the field and organization updates</p>

			{allPosts.length > 0 ? (
				<div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
					{allPosts.map((post) => (
						<a href={post.url} class="flex h-full flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
							<h2 class="text-lg font-semibold text-slate-900">{post.frontmatter.title}</h2>
							<p class="mt-2 text-xs font-medium uppercase tracking-[0.2em] text-slate-500">{post.frontmatter.date}</p>
							<p class="mt-4 text-sm text-slate-600">{post.frontmatter.excerpt}</p>
							<span class="mt-6 text-sm font-semibold text-slate-900 underline decoration-slate-300 underline-offset-4 transition hover:text-slate-700">Read more →</span>
						</a>
					))}
				</div>
			) : (
				<div class="mt-8 rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-6 text-sm text-slate-600">
					No blog posts available yet.
				</div>
			)}
		</div>
	</section>
</BaseLayout>
